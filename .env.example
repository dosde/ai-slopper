# Copy this file to .env and fill in your values
# Supabase global leaderboard (optional — falls back to localStorage without these)
VITE_SCORES_URL=https://<your-project-ref>.supabase.co/rest/v1/scores
VITE_SCORES_KEY=eyJ...   # anon/public key from Supabase Dashboard → Settings → API

# RevenueCat IAP keys (only used on native Android/iOS builds).
# Leave blank on web — tip jar will fall back to the external Ko-Fi link.
# Get these from RevenueCat Dashboard → your app → API keys.
VITE_REVENUECAT_ANDROID_KEY=goog_...
VITE_REVENUECAT_IOS_KEY=appl_...
